# Dependencies & build output
node_modules/
.next/
out/
build/
dist/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Large / regenerated data — the scheduled job re-downloads results.csv and
# shootouts.csv (a failed shootouts pull degrades gracefully to coin-flip pens).
# NOTE: web/public/data/*.json and model/data/output/*.json ARE committed
# (the static site reads them); transfermarkt_values.json is committed as a
# scrape fallback. Only the source CSVs and intermediates are ignored.
model/data/raw/results.csv
model/data/raw/shootouts.csv
model/data/processed/

# Env & local
.env
.env.*
.vercel/
.firebase/
firebase-debug.log
*.log
.DS_Store
Thumbs.db

# never commit service-account keys
*sa*.json
*service-account*.json
*-key.json
application_default_credentials.json
