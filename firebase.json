{
  "hosting": {
    "site": "gaffer-wc26",
    "public": "web/out",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/opengraph-image",
        "headers": [{ "key": "Content-Type", "value": "image/png" }]
      },
      {
        "source": "/data/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }]
      }
    ]
  }
}
